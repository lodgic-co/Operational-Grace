{
  "name": "operational-grace",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node --import ./dist/observability/otel-preload.js dist/index.js",
    "check": "tsc",
    "db:migrate": "node scripts/run-migrate.cjs",
    "db:seed:dev": "node scripts/run-seed-dev.cjs",
    "db:create-migration": "node-pg-migrate create --migrations-dir db/migrations",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "openapi:check": "redocly lint openapi/openapi.yaml --config openapi/.redocly.yaml",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "ci": "node scripts/assert-authority-derived-validator-bundles.mjs && node scripts/validate-governance-entrypoint.mjs && node scripts/validate-generated-artifact-ownership.mjs && pnpm typecheck && pnpm lint && pnpm openapi:check && pnpm verify:generated && pnpm db:migrate && pnpm test && pnpm build",
    "verify:generated": "node scripts/verify-generated-artifacts.cjs"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.73.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.215.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.215.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-logs": "^0.215.0",
    "@opentelemetry/sdk-metrics": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@opentelemetry/semantic-conventions": "^1.39.0",
    "@redocly/cli": "^2.28.1",
    "env-schema": "^7.0.0",
    "fastify": "^5.8.5",
    "jose": "^6.2.2",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.20.0",
    "undici": "^6.24.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.3.0",
    "js-yaml": "^4.1.1",
    "prettier": "^3.8.2",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "7.3.2",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20.0.0 <21.0.0"
  },
  "packageManager": "pnpm@10.26.1",
  "pnpm": {
    "overrides": {
      "vite": "7.3.2",
      "protobufjs": "7.5.5",
      "postcss": "8.5.10",
      "brace-expansion@2": "2.0.3",
      "brace-expansion@5": "5.0.5"
    }
  }
}

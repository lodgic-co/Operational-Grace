# operational-grace environment variables

PORT=5003
NODE_ENV=development
LOG_LEVEL=info

# Auth0 — M2M token validation (inbound)
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_ISSUER=https://your-tenant.auth0.com/
AUTH0_AUDIENCE=https://internal.your-domain.com/
# Comma-separated list of allowed Auth0 client IDs (azp claim):
AUTH0_ALLOWED_AZP=polite-intervention-m2m-client-id
AUTH0_JWKS_URI=https://your-tenant.auth0.com/.well-known/jwks.json

# Database (shared base URL — schema set per-pool at connect time)
DATABASE_URL=postgresql://user:pass@localhost:5432/lodgic_dev
DATABASE_URL_DIRECT=postgresql://user:pass@localhost:5432/lodgic_dev
DB_POOL_SIZE=5
DB_CONNECTION_TIMEOUT_MS=5000
DB_IDLE_TIMEOUT_MS=10000

# Cursor HMAC signing
CURSOR_HMAC_SECRET=change-me-in-production

# Auth0 — M2M token for outbound calls to measured-judgement
MEASURED_JUDGEMENT_BASE_URL=https://measured-judgement.internal
AUTH0_M2M_AUDIENCE=https://internal.your-domain.com/
AUTH0_M2M_CLIENT_ID=operational-grace-m2m-client-id
AUTH0_M2M_CLIENT_SECRET=change-me-in-production
AUTH0_TOKEN_URL=https://your-tenant.auth0.com/oauth/token

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=operational-grace
